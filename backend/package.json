{
  "name": "epiis-mcp-server",
  "version": "1.0.0",
  "description": "Servidor MCP para gestión académica EPIIS con Llama local",
  "type": "module",
  "main": "src/mcp/server.js",
  "scripts": {
    "start": "node src/mcp/server.js",
    "dev": "nodemon src/mcp/server.js",
    "api": "node src/app.js",
    "test": "node --experimental-vm-modules node_modules/.bin/jest --forceExit",
    "setup": "node scripts/setup.js",
    "index-docs": "node ../scripts/index-documents.js",
    "openclaw:setup": "node -e \"require('os').platform() === 'win32' ? require('child_process').execSync('powershell -ExecutionPolicy Bypass -File ../scripts/setup-openclaw.ps1', {stdio: 'inherit'}) : require('child_process').execSync('bash ../scripts/setup-openclaw.sh', {stdio: 'inherit'})\"",
    "openclaw:start": "node -e \"require('os').platform() === 'win32' ? require('child_process').execSync('powershell -ExecutionPolicy Bypass -File ../scripts/start-openclaw.ps1', {stdio: 'inherit'}) : require('child_process').execSync('bash ../scripts/start-openclaw.sh', {stdio: 'inherit'})\""
  },
  "keywords": [
    "mcp",
    "llama",
    "ollama",
    "academic",
    "document-management"
  ],
  "author": "EPIIS-UNAS",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.4",
    "axios": "^1.6.7",
    "better-sqlite3": "^12.6.2",
    "cheerio": "^1.0.0-rc.12",
    "chromadb": "^1.8.1",
    "cors": "^2.8.5",
    "docx": "^9.6.0",
    "docxtemplater": "^3.47.2",
    "dotenv": "^16.3.1",
    "exceljs": "^4.4.0",
    "express": "^4.18.2",
    "google-auth-library": "^10.5.0",
    "jsonwebtoken": "^9.0.3",
    "jszip": "^3.10.1",
    "lodash": "^4.17.21",
    "mammoth": "^1.6.0",
    "multer": "^1.4.5-lts.1",
    "ollama": "^0.5.9",
    "pdf-lib": "^1.17.1",
    "pdf-parse": "^1.1.1",
    "pizzip": "^3.1.7",
    "pptxgenjs": "^4.0.1",
    "qrcode": "^1.5.4",
    "whatsapp-web.js": "^1.34.6",
    "winston": "^3.11.0",
    "xlsx": "^0.18.5",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/node": "^20.11.17",
    "jest": "^29.7.0",
    "nodemon": "^3.0.3"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}