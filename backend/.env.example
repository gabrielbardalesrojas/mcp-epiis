# ============================================
# EPIIS MCP Server - Configuración
# ============================================

# --- Inferencia Híbrida (Local/Cloud) ---
IA_MODE=local  # Opciones: 'local' o 'cloud'
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.2:3b
EMBED_MODEL=nomic-embed-text

# --- Configuración Cloud (Necesaria para web_search/web_fetch) ---
OLLAMA_CLOUD_API_KEY=
OLLAMA_CLOUD_HOST=https://api.ollama.com
OLLAMA_CLOUD_MODEL=llama3.2:3b

# --- Servidor API ---
PORT=3001
NODE_ENV=development

# --- Rutas de Almacenamiento ---
STORAGE_PATH=./storage
DATA_PATH=./data

# --- LLM Options ---
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=4096
LLM_NUM_CTX=4096

# --- Vector Store (ChromaDB) ---
CHROMADB_PATH=./storage/chromadb
COLLECTION_NAME=epiis_documents

# --- Chunking ---
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
MIN_SIMILARITY_SCORE=0.5

# --- Web Scraping ---
UNSM_BASE_URL=https://www.unas.edu.pe
FIIS_URL=https://fiis.unas.edu.pe
SCRAPER_TIMEOUT=30000

# --- Logging ---
LOG_LEVEL=info
